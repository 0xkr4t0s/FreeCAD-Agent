# SPDX-FileNotice: https://EditorConfig.org


root = true


[*.{toml,xml,py,md,yml,yaml}]
insert_final_newline = false
indent_style = space
end_of_line = lf
indent_size = 4
charset = utf-8

[*.{toml,xml,py,yml,yaml}]
trim_trailing_whitespace = true

[*.{md}]
trim_trailing_whitespace = false
